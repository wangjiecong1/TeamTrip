VITE_API_BASE_URL=https://cricketchief.com
# Socket.IO 服务地址，只填写 origin；默认与 VITE_API_BASE_URL 同源。
# VITE_SOCKET_URL=https://cricketchief.com

VITE_AMAP_JSAPI_KEY=your-amap-web-jsapi-key
# 本地开发可使用安全密钥；生产环境推荐改用 VITE_AMAP_SERVICE_HOST。
VITE_AMAP_SECURITY_JS_CODE=your-amap-security-js-code
# VITE_AMAP_SERVICE_HOST=https://api.example.com/_AMapService
